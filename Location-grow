local COMMAND_DATA={
["jail"]=60,["ragdoll"]=30,["balloon"]=30,["jumpscare"]=60,["rocket"]=120,["inverse"]=60,["nightvision"]=60,["tiny"]=60,["morph"]=60
}
local CMDS_ORDER={"jail","ragdoll","balloon","jumpscare","rocket","inverse","nightvision","tiny","morph"}
local Settings={
Enabled=false,Range=30,CheckRate=0.5,NextActionDelay=3 
}
local rangeList={30,40,50,70,100}
