local function destroyOldRing()
for _,v in pairs(workspace:GetDescendants()) do
if v:IsA("Part") and v.Name=="APRing" then
v:Destroy()
end
end
end
destroyOldRing()
local function click(btn)
if not btn then return end
pcall(function()
for _,c in pairs(getconnections(btn.MouseButton1Click)) do c:Fire() end
for _,c in pairs(getconnections(btn.Activated)) do c:Fire() end
end)
end
local function isCommandReady(cmdName)
local readyAt=globalCooldowns[cmdName] or 0
return tick() >=readyAt
end
local function getReadyCommands(amount)
local selected={}
for _,name in ipairs(CMDS_ORDER) do
if #selected >=amount then break end
if isCommandReady(name) then
table.insert(selected,name)
end
end
return selected
end
local function runSmartSequence(target)
if playerProcessing[target.UserId] then return end
playerProcessing[target.UserId]=true
task.spawn(function()
local panel=player:WaitForChild("PlayerGui"):FindFirstChild("AdminPanel")
if not panel then playerProcessing[target.UserId]=false return end
local function executeBatch(amt)
local stringsToSearch=getReadyCommands(amt)
if #stringsToSearch==0 then return false end
local pBtn=nil
for _,d in pairs(panel:GetDescendants()) do
if (d:IsA("TextButton") or d:IsA("ImageButton")) and (d.Name:find(target.Name) or (d:FindFirstChildOfClass("TextLabel") and d:FindFirstChildOfClass("TextLabel").Text:find(target.Name))) then
pBtn=d break
end
end
if pBtn then
for _,d in pairs(panel:GetDescendants()) do
if d:IsA("TextButton") or d:IsA("ImageButton") then
local txt=(d:IsA("TextButton") and d.Text or (d:FindFirstChildOfClass("TextLabel") and d:FindFirstChildOfClass("TextLabel").Text or "")):lower()
for _,cmd in ipairs(stringsToSearch) do
if txt:find(cmd) and (txt:find("^:") or txt:find("^;")) then
click(pBtn)
click(d)
globalCooldowns[cmd]=tick() + COMMAND_DATA[cmd]
end
end
end
end
return true
end
return false
end
executeBatch(3)
task.wait(Settings.NextActionDelay)
local root=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
local tRoot=target.Character and target.Character:FindFirstChild("HumanoidRootPart")
if Settings.Enabled and root and tRoot and (root.Position - tRoot.Position).Magnitude <=Settings.Range then
executeBatch(3)
task.wait(Settings.NextActionDelay)
if Settings.Enabled and root and tRoot and (root.Position - tRoot.Position).Magnitude <=Settings.Range then
executeBatch(1)
end
end
playerProcessing[target.UserId]=nil
end)
end
