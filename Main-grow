local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local task = task

local TpToBestSystem = {}
TpToBestSystem.Enabled = false
TpToBestSystem.Connections = {}
TpToBestSystem.isStopping = false
TpToBestSystem.hasReachedHeight = false
TpToBestSystem.targetHeight = nil
TpToBestSystem.currentBestPet = nil
TpToBestSystem.baseCoordinates = {
    ["Base 1"] = Vector3.new(-475.9, 17.5, -102.3),
    ["Base 2"] = Vector3.new(-342.8, 17.5, -100.2),
    ["Base 3"] = Vector3.new(-342.9, 17.5, 6.2),
    ["Base 4"] = Vector3.new(-343.1, 17.5, 112.6),
    ["Base 5"] = Vector3.new(-343.3, 17.5, 220.8),
    ["Base 6"] = Vector3.new(-476.2, 17.5, 219.7),
    ["Base 7"] = Vector3.new(-476.1, 17.5, 114.1),
    ["Base 8"] = Vector3.new(-476.5, 17.5, 6.6)
}

local function parseValue(text)
    text = tostring(text or ""):gsub("%s", "")
    local num, suffix = text:match("([%d%.]+)([KkMmBbTt]?)")
    if not num then return 0 end
    num = tonumber(num) or 0
    local multipliers = {K=1e3, M=1e6, B=1e9, T=1e12}
    local mult = multipliers[(suffix or ""):upper()] or 1
    return num * mult
end

function TpToBestSystem:getValidFlyTool()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local toolNames = {"Flying Carpet", "Witch's Broom", "Santa's Sleigh"}
    for _, name in ipairs(toolNames) do
        local tool = (backpack and backpack:FindFirstChild(name)) or (char and char:FindFirstChild(name))
        if tool then return tool end
    end
    return nil
end

function TpToBestSystem:findClosestBase(petPosition)
    local closestBase = nil
    local closestDistance = math.huge
    for baseName, baseCoord in pairs(self.baseCoordinates) do
        local distance = (petPosition - baseCoord).Magnitude
        if distance < closestDistance then
            closestDistance = distance
            closestBase = baseName
        end
    end
    return closestBase
end

function TpToBestSystem:findMostExpensiveBrainrot()
    if self.isStopping then return nil end
    local Workspace = game:GetService("Workspace")
    local debris = Workspace:FindFirstChild("Debris")
    if not debris then return nil end
    local bestPet = {value = -1, part = nil}
    for _, template in ipairs(debris:GetChildren()) do
        if template.Name == "FastOverheadTemplate" then
            local surfaceGui = template:FindFirstChildOfClass("SurfaceGui")
            if surfaceGui and surfaceGui.Adornee and surfaceGui.Adornee.Parent then
                local genLabel = surfaceGui:FindFirstChild("Generation", true)
                if genLabel and genLabel:IsA("TextLabel") then
                    local text = genLabel.Text or ""
                    if text ~= "" and (text:find("/s") or text:find("K") or text:find("M") or text:find("B") or text:find("T")) then
                        local val = parseValue(text)
                        if val > bestPet.value then
                            bestPet.value = val
                            bestPet.part = surfaceGui.Adornee
                        end
                    end
                end
            end
        end
    end
    if bestPet.part then
        return {position = bestPet.part.Position, baseName = self:findClosestBase(bestPet.part.Position)}
    end
    return nil
end

function TpToBestSystem:equipTool()
    local tool = self:getValidFlyTool()
    if tool and tool.Parent == LocalPlayer:FindFirstChild("Backpack") then
        local char = LocalPlayer.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid:EquipTool(tool) end
    end
    return tool
end

function TpToBestSystem:stopMovement()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
end

function TpToBestSystem:cleanStop()
    self.isStopping = true
    self.hasReachedHeight = false
    self.targetHeight = nil
    for _, conn in pairs(self.Connections) do
        if conn then conn:Disconnect() end
    end
    self.Connections = {}
    self:stopMovement()
    task.wait(0.1)
    self.isStopping = false
end

function TpToBestSystem:teleportToBestBrainrot()
    if self.isStopping then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not self.currentBestPet then return end
    local targetBase = self.baseCoordinates[self.currentBestPet.baseName]
    hrp.CFrame = CFrame.new(targetBase or self.currentBestPet.position)
    task.wait(0.5)
    self:cleanStop()
end

function TpToBestSystem:startSystem()
    if self.Enabled then return end
    
    local tool = self:getValidFlyTool()
    if not tool then
        warn("No tool found!")
        return
    end

    self.Enabled = true
    self.isStopping = false
    self.hasReachedHeight = false
    self.currentBestPet = self:findMostExpensiveBrainrot()
    
    if not self.currentBestPet then
        self.Enabled = false
        return
    end
    
    self:equipTool()
    task.wait(0.2)
    
    self.Connections.movement = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or self.isStopping then return end
        
        if not self.hasReachedHeight then
            if not self.targetHeight then
                self.targetHeight = Vector3.new(hrp.Position.X, hrp.Position.Y + 35, hrp.Position.Z)
            end
            
            if (hrp.Position - self.targetHeight).Magnitude > 3 then
                hrp.AssemblyLinearVelocity = (self.targetHeight - hrp.Position).Unit * 100
            else
                self.hasReachedHeight = true
                self:stopMovement()
                task.wait(0.1)
                self:teleportToBestBrainrot()
                self.Enabled = false
            end
        end
    end)
end

TpToBestSystem:startSystem()
