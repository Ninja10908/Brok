UIList.Padding=UDim.new(0,2)
UIList.HorizontalAlignment=Enum.HorizontalAlignment.Center
UIList.SortOrder=Enum.SortOrder.LayoutOrder
local dragging=false
local dragInput
local dragStart
local startPos
header.InputBegan:Connect(function(i)
if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
dragging=true
dragStart=i.Position
startPos=main.Position
i.Changed:Connect(function()if i.UserInputState==Enum.UserInputState.End then dragging=false end end)
end
end)
header.InputChanged:Connect(function(i)if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then dragInput=i end end)
UserInputService.InputChanged:Connect(function(i)if i==dragInput and dragging then local d=i.Position-dragStart main.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)end end)
local minimized=true
local function toggle()
minimized=not minimized
if minimized then
arrow.Text="▼"
container.Size=UDim2.new(1,0,0,0)
main.Size=UDim2.new(0,150,0,28)
else
arrow.Text="▲"
local pc=#Players:GetPlayers()-1
local h=math.min(pc*36,250)
container.Size=UDim2.new(1,0,0,h)
main.Size=UDim2.new(0,150,0,28+h)
end
end
header.MouseButton1Click:Connect(toggle)
local function updatePlayerList()
for _,v in pairs(playerList:GetChildren())do if v:IsA("TextButton")then v:Destroy()end end
local ps={}for _,p in pairs(Players:GetPlayers())do if p~=player then table.insert(ps,p)end end
for _,p in pairs(ps)do
local btn=Instance.new("TextButton",playerList)
btn.Size=UDim2.new(1,-8,0,34)
btn.BackgroundColor3=Color3.fromRGB(20,20,20)
btn.BorderSizePixel=0
btn.Text=""
btn.AutoButtonColor=false
Instance.new("UICorner",btn).CornerRadius=UDim.new(0,4)
local avatar=Instance.new("ImageLabel",btn)
avatar.Size=UDim2.new(0,24,0,24)
avatar.Position=UDim2.new(0,5,0.5,-12)
avatar.BackgroundColor3=Color3.fromRGB(30,30,30)
avatar.Image="rbxthumb://type=AvatarHeadShot&id="..p.UserId.."&w=48&h=48"
avatar.BorderSizePixel=0
Instance.new("UICorner",avatar).CornerRadius=UDim.new(1,0)
local name=Instance.new("TextLabel",btn)
name.Size=UDim2.new(1,-35,0,28)
name.Position=UDim2.new(0,34,0.5,-14)
name.BackgroundTransparency=1
name.Text=p.DisplayName
name.TextColor3=isStealing(p)and Color3.fromRGB(255,50,50)or Color3.fromRGB(255,255,255)
name.TextSize=11
name.Font=Enum.Font.GothamBold
name.TextXAlignment=Enum.TextXAlignment.Left
name.TextYAlignment=Enum.TextYAlignment.Center
btn.MouseEnter:Connect(function()tw(btn,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(30,30,30)})end)
btn.MouseLeave:Connect(function()tw(btn,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(20,20,20)})end)
local target=p
btn.MouseButton1Click:Connect(function()
tw(btn,TweenInfo.new(0.05),{BackgroundColor3=Color3.fromRGB(45,45,45)})
task.delay(0.1,function()tw(btn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(20,20,20)})end)
spamPlayer(target)
end)
end
playerList.CanvasSize=UDim2.new(0,0,0,#ps*36)
if not minimized then local h=math.min(#ps*36,250)container.Size=UDim2.new(1,0,0,h)main.Size=UDim2.new(0,150,0,28+h)end
end
local function attributeChanged(p)for _,v in pairs(playerList:GetChildren())do if v:IsA("TextButton")then local lbl=v:FindFirstChildWhichIsA("TextLabel")if lbl and lbl.Text==p.DisplayName then lbl.TextColor3=isStealing(p)and Color3.fromRGB(255,50,50)or Color3.fromRGB(255,255,255)end end end end
local function onPlayerAdded(p)p.AttributeChanged:Connect(function()attributeChanged(p)end)end
updatePlayerList()
Players.PlayerAdded:Connect(function(p)updatePlayerList()onPlayerAdded(p)end)
Players.PlayerRemoving:Connect(updatePlayerList)
for _,p in pairs(Players:GetPlayers())do if p~=player then onPlayerAdded(p)end end
