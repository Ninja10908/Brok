local Players=game:GetService("Players")
local TweenService=game:GetService("TweenService")
local UserInputService=game:GetService("UserInputService")
local CoreGui=game:GetService("CoreGui")
local player=Players.LocalPlayer
if CoreGui:FindFirstChild("APSpammer") then CoreGui["APSpammer"]:Destroy() end
local function tw(o,i,p) TweenService:Create(o,i,p):Play() end
local function findAdminPanel()
return player:WaitForChild("PlayerGui"):FindFirstChild("AdminPanel")
end
local function clickButton(button)
pcall(function()
for _,c in pairs(getconnections(button.MouseButton1Click)) do c:Fire() end
for _,c in pairs(getconnections(button.Activated)) do c:Fire() end
end)
end
local function findPlayerButton(targetPlayer)
local adminPanel=findAdminPanel()
if not adminPanel then return nil end
for _,d in pairs(adminPanel:GetDescendants()) do
if d:IsA("TextButton") or d:IsA("ImageButton") then
local txt=d:IsA("TextButton") and d.Text or ""
if txt=="" then
for _,child in pairs(d:GetDescendants()) do
if child:IsA("TextLabel") then txt=child.Text break end
end
end
if txt==targetPlayer.DisplayName or txt==targetPlayer.Name or txt:find(targetPlayer.DisplayName) or txt:find(targetPlayer.Name) then
return d
end
end
end
return nil
end
local function getCommandButtons()
local buttons={}
local adminPanel=findAdminPanel()
if not adminPanel then return buttons end
for _,d in pairs(adminPanel:GetDescendants()) do
if d:IsA("TextButton") or d:IsA("ImageButton") then
local txt=d:IsA("TextButton") and d.Text or ""
if txt=="" then
for _,child in pairs(d:GetDescendants()) do
if child:IsA("TextLabel") and child.Text ~="" then txt=child.Text break end
end
end
if txt and txt ~="" and (txt:match("^:") or txt:match("^;")) then
table.insert(buttons,{button=d,name=txt:lower()})
end
end
end
return buttons
end
local CMDS={"rocket","morph","inverse","ragdoll","balloon","nightvision","jumpscare","jail","tiny"}
local function spamPlayer(targetPlayer)
task.spawn(function()
local adminPanel=findAdminPanel()
if not adminPanel then return end
local cmdButtons=getCommandButtons()
local playerBtn=findPlayerButton(targetPlayer)
if not playerBtn then return end
local toExec={}
for _,cb in pairs(cmdButtons) do
for _,cmd in ipairs(CMDS) do
if cb.name:find(cmd) then
table.insert(toExec,cb)
break
end
end
end
for _,cb in ipairs(toExec) do
clickButton(playerBtn)
clickButton(cb.button)
end
end)
end
