local Players=game:GetService("Players")
local TweenService=game:GetService("TweenService")
local UserInputService=game:GetService("UserInputService")
local CoreGui=game:GetService("CoreGui")
local player=Players.LocalPlayer
if CoreGui:FindFirstChild("APSpammer") then CoreGui["APSpammer"]:Destroy() end
local function tw(o,i,p)TweenService:Create(o,i,p):Play()end
local function findAdminPanel()return player:WaitForChild("PlayerGui"):FindFirstChild("AdminPanel")end
local function clickButton(b)pcall(function()for _,c in pairs(getconnections(b.MouseButton1Click))do c:Fire()end for _,c in pairs(getconnections(b.Activated))do c:Fire()end end)end
local function findPlayerButton(t)
local a=findAdminPanel()if not a then return nil end
for _,d in pairs(a:GetDescendants())do
if d:IsA("TextButton")or d:IsA("ImageButton")then
local txt=d:IsA("TextButton")and d.Text or""
if txt==""then for _,c in pairs(d:GetDescendants())do if c:IsA("TextLabel")then txt=c.Text break end end end
if txt==t.DisplayName or txt==t.Name or txt:find(t.DisplayName)or txt:find(t.Name)then return d end
end end
return nil
end
local function getCommandButtons()
local b={}local a=findAdminPanel()if not a then return b end
for _,d in pairs(a:GetDescendants())do
if d:IsA("TextButton")or d:IsA("ImageButton")then
local txt=d:IsA("TextButton")and d.Text or""
if txt==""then for _,c in pairs(d:GetDescendants())do if c:IsA("TextLabel")and c.Text~=""then txt=c.Text break end end end
if txt and txt~=""and(txt:match("^:")or txt:match("^;"))then table.insert(b,{button=d,name=txt:lower()})end
end
end
return b
end
local CMDS={"rocket","morph","inverse","ragdoll","balloon","nightvision","jumpscare","jail","tiny"}
local function spamPlayer(t)
task.spawn(function()
local a=findAdminPanel()if not a then return end
local cb=getCommandButtons()
local pb=findPlayerButton(t)
if not pb then return end
local te={}
for _,c in pairs(cb)do for _,cmd in ipairs(CMDS)do if c.name:find(cmd)then table.insert(te,c)break end end end
for _,c in pairs(te)do clickButton(pb)clickButton(c.button)end
end)
end
local function isStealing(p)return p:GetAttribute("Stealing")==true end
